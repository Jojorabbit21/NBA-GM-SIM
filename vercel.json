{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "(?!basketballgm\\.app).*\\.vercel\\.app" }],
      "destination": "https://basketballgm.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
